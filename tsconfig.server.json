{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "strict": false,
        "skipLibCheck": true,
        "outDir": "dist-server",
        "baseUrl": "."
    },
    "ts-node": {
        "transpileOnly": true,
        "compilerOptions": {
            "module": "CommonJS"
        }
    },
    "include": [
        "simulation-engine.ts"
    ],
    "exclude": [
        "node_modules",
        "src"
    ]
}